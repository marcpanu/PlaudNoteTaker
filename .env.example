# Plaud device access (obtain from Plaud website dev tools)
PLAUD_BEARER_TOKEN=

# AssemblyAI (transcription + diarization)
ASSEMBLYAI_API_KEY=

# Gemini (LLM summarization)
GEMINI_API_KEY=

# Picovoice Eagle (speaker recognition)
PICOVOICE_ACCESS_KEY=

# Obsidian vault path (absolute path to your vault root)
VAULT_PATH=

# Subfolder within vault for notes (relative to vault root)
VAULT_NOTES_FOLDER=Meeting Notes

# Folder for custom note templates (absolute path, or relative to vault root)
# Templates are .md files. Falls back to built-in default if not set or empty.
TEMPLATES_PATH=

# Selected template filename (without .md extension). Default: "Default"
SELECTED_TEMPLATE=Default

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# Polling interval in seconds
POLL_INTERVAL=60

# Data directory for local state (processed recordings log, speaker profiles)
DATA_DIR=./data
